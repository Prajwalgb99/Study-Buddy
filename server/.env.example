# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Get this from: MongoDB Atlas → Your Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/study-buddy?retryWrites=true&w=majority

# ─── Google Gemini ────────────────────────────────────────────────────────────
# Get this from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_long_change_this

# ─── Vector Search ────────────────────────────────────────────────────────────
# Name of the Vector Search index you create in MongoDB Atlas
VECTOR_INDEX_NAME=vector_index

# ─── File Upload ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20
UPLOAD_DIR=uploads

# ─── Chunking Settings ────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100
